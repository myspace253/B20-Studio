DATABASE_URL="postgresql://user:password@localhost:5432/base_studio"
# Only needed if DATABASE_URL points at a connection pooler (PgBouncer,
# Supabase's pooler, Prisma Accelerate, etc.) — migrations need a direct
# connection. If DATABASE_URL is already a direct connection, set this to
# the same value.
DIRECT_URL="postgresql://user:password@localhost:5432/base_studio"

# Your production URL — used for correct Open Graph/canonical URLs.
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# NextAuth (SIWE) — generate with: npx auth secret
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_PUBLIC_URL=""

POSTHOG_KEY=""
